>>>>>>> origin/main
DB_ENGINE=django.db.backends.mysql
DB_NAME=eat_what
DB_USER=your_db_user
DB_PASSWORD=your_db_password
DB_HOST=127.0.0.1
DB_PORT=3306

# --- NVIDIA Integrate（美食助理 AI）---
NVIDIA_API_KEY=your_nvidia_api_key_here
NVIDIA_MODEL=qwen/qwen3.5-397b-a17b

# 可選：NVIDIA 備援（主模型 timeout / 失敗時自動切換）
# 常見取捨：主模型用大顆（較準、較慢）＋備援用小顆 vision（較快、品質可能較粗）；
# 若你希望「永遠同一顆」可把備援也設成與 NVIDIA_MODEL 相同。
NVIDIA_BACKUP_API_KEY=
NVIDIA_BACKUP_MODEL=meta/llama-3.2-11b-vision-instruct

# 請求逾時秒數（美食助理對話）
AI_REQUEST_TIMEOUT_SECONDS=35
# 健康達人分析逾時（含傳圖，建議 60～120 秒）
AI_HEALTH_REQUEST_TIMEOUT_SECONDS=90

# --- JWT（DRF API）---
JWT_ACCESS_MINUTES=60
JWT_REFRESH_DAYS=7

# --- Celery / Redis（健康分析非同步任務；可沿用預設）---
CELERY_BROKER_URL=redis://127.0.0.1:6379/0
CELERY_RESULT_BACKEND=redis://127.0.0.1:6379/1
# 設為 1 時任務同步執行（無 Redis 時除錯用，不建議正式環境）
# CELERY_TASK_ALWAYS_EAGER=0

# --- Google Gemini（可作為最後備援）---
# 支援兩種命名（二擇一即可）：
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
# 或沿用你目前第三組改名：
NVIDIA_BACKUP_API_KEY2=
NVIDIA_BACKUP_MODEL2=gemini-2.0-flash
